*.xlsx
*.docx
.DS_Store

# Internal-only docs (not for the public repo)
Project_notes.md
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# Copyrighted reference PDFs -- keep locally, don't redistribute (repo is public)
Reproducibility_articles/

# Derived/ and Figures/ contents are recreatable and ignored by default; folders are kept via .gitkeep.
# Exception: the anonymized registrant CSV and map PNG are safe to share, so they're committed as a worked example.
Derived/*
!Derived/.gitkeep
!Derived/registrants_public.csv
Figures/*
!Figures/.gitkeep
!Figures/registrants_map.png

# Depends on the gitignored raw xlsx, so it can't run for anyone who only has this repo -- kept local only.
Scripts/00a_wrangling.R

# Quarto render byproducts (recreate with `quarto render`)
Scripts/qmd/*.html
Scripts/qmd/*.pdf
Scripts/qmd/*_files/
Scripts/qmd/*_cache/
/.quarto/
