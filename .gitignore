# (no emails/full last names) and are committed as a worked example.
Derived/*
!Derived/.gitkeep
!Derived/registrants_public.csv
Figures/*
!Figures/.gitkeep
!Figures/registrants_map.png

# Quarto render byproducts (recreate with `quarto render`)
Scripts/qmd/*.html
Scripts/qmd/*.pdf
Scripts/qmd/*_files/
Scripts/qmd/*_cache/
/.quarto/
